/* reset */
a {
  color: gray;
  text-decoration-line: none; }

ul, ol {
  list-style: none;
  margin: 0px;
  padding: 0px; }

.hero {
  /* view */
  min-height: 100vh;
  width: 100vw;
  /* flex */
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center; }

.single-title {
  text-align: center; }

.body {
  display: grid;
  grid-row: auto 1fr auto; }
