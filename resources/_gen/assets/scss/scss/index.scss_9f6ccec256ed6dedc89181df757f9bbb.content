@charset "UTF-8";.single-title{text-align:center}a{color:gray;text-decoration-line:none}ul,ol{list-style:none;margin:0;padding:0}.nav-title{display:flex;align-items:center;margin-left:32px}.nav-title-text{margin-left:16px}.navbar{display:flex;justify-content:space-between;margin:0 auto;border-bottom:1px solid grey}.menubar{display:flex;align-items:flex-end;justify-content:center}.menu{display:block;padding:16px}.footer{background-color:#eee}.sitemap{text-align:center;padding:2.5rem;display:grid;grid-template-columns:1fr 1fr}.link-item{margin-left:16px;margin-top:16px}.hero{min-height:100vh;width:100vw;display:flex;flex-direction:column;align-items:center;justify-content:center}.blog-content{display:grid;grid-template-columns:1fr minmax(150px,25%)}.blog-aside{margin-left:32px}.post{border:2px solid;border-radius:6px;cursor:pointer}.copyright{text-align:center}